# HTTP server
PORT=8080
HOST=0.0.0.0

# Root directory of the managed files (sandboxed)
FILES_ROOT=/data

# Authentication: basic | keycloak | none
AUTH_METHOD=none

# Required when AUTH_METHOD=basic
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Required when AUTH_METHOD=keycloak
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=file-manager
KEYCLOAK_CLIENT_ID=file-manager
